{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.sanjeevkkansal/solfleet",
  "description": "Agent-safe fleet management for independent Solana validators and RPC nodes",
  "repository": {
    "url": "https://github.com/sanjeevkkansal/solfleet",
    "source": "github"
  },
  "version": "0.1.1",
  "packages": [
    {
      "registryType": "pypi",
      "registryBaseUrl": "https://pypi.org",
      "identifier": "solfleet",
      "version": "0.1.1",
      "runtimeHint": "uvx",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        { "type": "named", "name": "--from", "value": "solfleet" },
        { "type": "positional", "value": "solfleet-mcp" }
      ]
    }
  ]
}
